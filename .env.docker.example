# Copy to backend/.env (or export before docker compose up)
OPENAI_API_KEY=your_key_here

# Optional overrides for docker compose (backend service)
# DATABASE_URL is set automatically to use the postgres service name.
# CORS_ORIGINS is set automatically for the containerized frontend on port 8080.

# Frontend build-time API URL (browser-accessible backend URL)
# VITE_API_BASE_URL=http://localhost:8000
